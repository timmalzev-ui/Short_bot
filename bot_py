# ================== SCAN ==================
def scan_market():
    global stats
    symbols = get_all_linear_symbols()[:MAX_SYMBOLS]
    if not symbols: return

    with stats_lock:
        stats["scan_count"] += 1
        stats["symbols_total"] += len(symbols)

    for sym in symbols:
        ticker = get_ticker(sym)
        if not ticker or ticker["price24hPcnt"] < MIN_PUMP_24H or ticker["turnover24h"] < MIN_TURNOVER_24H:
            continue
        with stats_lock: stats["after_pump"] += 1

        funding, longs = get_funding_rate(sym), get_long_short_ratio(sym)
        if funding < MIN_FUNDING or longs < MIN_LONGS: continue
        with stats_lock: stats["after_sentiment"] += 1

        klines = get_recent_klines(sym)
        if not klines: continue

        exhaustion, vol_climax, fake_break = is_exhaustion_pattern(klines), is_volume_climax(klines), is_fake_breakout(klines)
        if not (exhaustion and vol_climax and fake_break): continue
        with stats_lock: stats["after_patterns"] += 1

        cvd_manager.subscribe_symbol(sym)
        cvd_val, prices = cvd_manager.get_snapshot(sym)
        if not prices: continue

        divergence = check_bearish_divergence(prices, cvd_val)
        if not divergence:
            with near_signals_lock:
                near_signals.append({"symbol": sym, "ticker": ticker, "funding": funding, "longs": longs, "cvd": cvd_val, "reason": "Нет CVD-дивергенции", "score": 0})
            continue
        with stats_lock: stats["after_cvd"] += 1

        score = calc_score(ticker, funding, longs, cvd_val, fake_break)
        if score < 5:
            with near_signals_lock:
                near_signals.append({"symbol": sym, "ticker": ticker, "funding": funding, "longs": longs, "cvd": cvd_val, "reason": f"Score {score}/8", "score": score})
            continue

        # 🔥 РЕАЛЬНЫЙ СИГНАЛ
        with stats_lock: stats["signals"] += 1
        price = ticker["lastPrice"]
        risk_amount = ACCOUNT_EQUITY * (RISK_PER_TRADE_PCT / 100)
        stop_distance = price * (STOP_PCT / 100)
        position_size = risk_amount / stop_distance if stop_distance > 0 else 0
        tp1_price = price * (1 - (STOP_PCT / 100) * TP1_RR)
        tp2_price = price * (1 - (STOP_PCT / 100) * TP2_RR)

        why_text = "• Сильный памп + ликвидность\n• Высокий funding + лонги\n• Exhaustion + volume climax\n• Fake breakout\n• CVD дивергенция"
        msg = (f"🔥 **SHORT {sym}** (Score: {score}/8)\n\n"
               f"📈 +{ticker['price24hPcnt']:.1f}% | {price:.5f}\n"
               f"💸 Funding: {funding:.3f}% | 👥 Лонги: {longs:.0f}%\n\n"
               f"🧠 *Почему:* {why_text}\n\n"
               f"🎯 Стоп: +{STOP_PCT}% | TP1: 1:{TP1_RR} | TP2: 1:{TP2_RR}\n"
               f"💼 Риск: {risk_amount:.0f}$ | Размер: {position_size:.0f}\n"
               f"https://www.bybit.com/trade/usdt/{sym}")
        send_telegram_message(msg)

def send_periodic_report():
    global last_report_time
    if datetime.utcnow() - last_report_time < timedelta(hours=REPORT_INTERVAL_HOURS): return
    
    with stats_lock: s = stats.copy()
    with near_signals_lock:
        sorted_near = sorted(near_signals, key=lambda x: x.get("score", 0), reverse=True)[:MAX_NEAR_SIGNALS_IN_REPORT]
    
    lines = [f"📊 *ОТЧЁТ* ({datetime.now().strftime('%H:%M')})",
             f"Сканирований: {s['scan_count']}",
             f"Монет: {s['symbols_total']} | Памп: {s['after_pump']}",
             f"Сентимент: {s['after_sentiment']} | Паттерны: {s['after_patterns']}",
             f"CVD: {s['after_cvd']} | Сигналов: {s['signals']}", ""]
    
    if sorted_near:
        lines.append("⚠️ *Почти сигналы:*")
        for c in sorted_near:
            lines.append(f"{c['symbol']}: {c['ticker']['price24hPcnt']:.1f}% | score {c['score']} — {c['reason']}")
    else:
        lines.append("ℹ️ Почти сигналов нет")
    
    send_telegram_message("\n".join(lines))
    reset_stats()

