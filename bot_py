# ================== ПАТТЕРНЫ ==================
def is_exhaustion_pattern(klines: List[List[str]]) -> bool:
    if len(klines) < 30: return False
    recent = klines[:30]
    bodies = []
    green_count = 0
    for k in recent:
        o, c = float(k[1]), float(k[4])
        body = abs(c - o)
        bodies.append(body)
        if c > o: green_count += 1
    if green_count < 18: return False
    avg_body = sum(bodies[5:]) / max(1, len(bodies[5:]))
    return bodies[0] >= avg_body * 2.0

def is_volume_climax(klines: List[List[str]]) -> bool:
    if len(klines) < 35: return False
    volumes = [float(k[5]) for k in klines[:35]]
    last_vol = volumes[0]
    avg_prev_vol = sum(volumes[5:]) / max(1, len(volumes[5:]))
    return last_vol >= avg_prev_vol * 3.0 and avg_prev_vol > 0

def is_fake_breakout(klines: List[List[str]]) -> bool:
    if len(klines) < 40: return False
    last = klines[0]
    prev_window = klines[1:31]
    high_last, close_last = float(last[2]), float(last[4])
    prev_high = max(float(k[2]) for k in prev_window)
    prev_low = min(float(k[3]) for k in prev_window)
    return high_last > prev_high and prev_low < close_last < prev_high

# ================== CVD MANAGER ==================
class CVDManager:
    def __init__(self, url: str = "wss://stream.bybit.com/v5/public/linear"):
        self.url = url
        self.ws = None
        self.thread = None
        self._lock = threading.Lock()
        self.cvd: Dict[str, float] = {}
        self.prices: Dict[str, List[float]] = {}
        self.subscribed: set[str] = set()
        self._running = False

    def _on_message(self, ws, message: str):
        try:
            data = json.loads(message)
            if not data.get("topic", "").startswith("publicTrade."): return
            symbol = data["topic"].split(".")[1]
            trades = data.get("data", [])
            with self._lock:
                for t in trades:
                    price = float(t["p"])
                    self.prices.setdefault(symbol, []).append(price)
                    if len(self.prices[symbol]) > 300:
                        self.prices[symbol] = self.prices[symbol][-300:]
                    delta = float(t["v"]) if t["S"] == "Buy" else -float(t["v"])
                    self.cvd[symbol] = self.cvd.get(symbol, 0.0) + delta
        except: pass

    def _on_open(self, ws):
        logger.info("✅ CVD WebSocket opened")
        self._resubscribe(ws)

    def _on_error(self, ws, error): logger.error("CVD WS error: %s", error)
    def _on_close(self, ws, code, msg): logger.warning("CVD WS closed")

    def _run(self):
        self.ws = websocket.WebSocketApp(self.url, 
            on_message=self._on_message, on_open=self._on_open,
            on_error=self._on_error, on_close=self._on_close)
        self.ws.run_forever()

    def start(self):
        if self._running: return
        self._running = True
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()

    def subscribe_symbol(self, symbol: str):
        with self._lock:
            if symbol in self.subscribed: return
            self.subscribed.add(symbol)
        if self.ws:
            self.ws.send(json.dumps({"op": "subscribe", "args": [f"publicTrade.{symbol}"]}))

    def _resubscribe(self, ws):
        with self._lock:
            if self.subscribed:
                ws.send(json.dumps({"op": "subscribe", "args": [f"publicTrade.{s}" for s in self.subscribed]}))

    def get_snapshot(self, symbol: str) -> Tuple[float, List[float]]:
        with self._lock:
            return self.cvd.get(symbol, 0.0), list(self.prices.get(symbol, []))

# ================== ДИВЕРГЕНЦИЯ + СКОР ==================
def check_bearish_divergence(prices: List[float], cvd_value: float) -> bool:
    if len(prices) < 60: return False
    swing_highs = []
    for i in range(2, len(prices)-2):
        if prices[i] == max(prices[i-2:i+3]): swing_highs.append((i, prices[i]))
    if len(swing_highs) < 2: return False
    (_, price_prev), (_, price_last) = swing_highs[-2:]
    return price_last > price_prev and cvd_value <= 0

def calc_score(ticker: Dict, funding: float, longs: float, cvd_val: float, fake_breakout: bool) -> int:
    score = 0
    if ticker["price24hPcnt"] > 40: score += 1
    if ticker["turnover24h"] > 25_000_000: score += 1
    if funding > 0.15: score += 1
    if longs > 78: score += 1
    if cvd_val < 0: score += 2
    if fake_breakout: score += 2
    return score

