# ================== SCAN ==================
def scan_market():
    global stats
    logger.info("Starting market scan")
    symbols = get_all_linear_symbols()
    if not symbols:
        logger.warning("No symbols returned from instruments-info")
        return

    symbols = symbols[:MAX_SYMBOLS]

    with stats_lock:
        stats["scan_count"] += 1
        stats["symbols_total"] += len(symbols)

    for sym in symbols:
        ticker = get_ticker(sym)
        if not ticker:
            continue

        if (
            ticker["price24hPcnt"] < MIN_PUMP_24H
            or ticker["turnover24h"] < MIN_TURNOVER_24H
        ):
            continue

        with stats_lock:
            stats["after_pump"] += 1

        funding = get_funding_rate(sym)
        if funding < MIN_FUNDING:
            continue

        longs = get_long_short_ratio(sym)
        if longs < MIN_LONGS:
            continue

        with stats_lock:
            stats["after_sentiment"] += 1

        klines = get_recent_klines(sym)
        if not klines:
            continue

        exhaustion = is_exhaustion_pattern(klines)
        if not exhaustion:
            continue

        vol_climax = is_volume_climax(klines)
        if not vol_climax:
            continue

        fake_break = is_fake_breakout(klines)
        if not fake_break:
            continue

        with stats_lock:
            stats["after_patterns"] += 1

        cvd_manager.subscribe_symbol(sym)
        cvd_val, prices = cvd_manager.get_snapshot(sym)
        if not prices:
            continue

        divergence = check_bearish_divergence(prices, cvd_val)
        if not divergence:
            # Кандидат «почти»: дошёл до CVD, но дивергенции нет
            candidate = {
                "symbol": sym,
                "ticker": ticker,
                "funding": funding,
                "longs": longs,
                "cvd": cvd_val,
                "reason": "Нет CVD‑дивергенции",
                "score": 0,
            }
            with near_signals_lock:
                near_signals.append(candidate)
            continue

        with stats_lock:
            stats["after_cvd"] += 1

        score = calc_score(ticker, funding, longs, cvd_val, fake_break)

        # «Почти сигнал» по score
        if score < 5:
            candidate = {
                "symbol": sym,
                "ticker": ticker,
                "funding": funding,
                "longs": longs,
                "cvd": cvd_val,
                "reason": f"Score {score}/8 ниже порога 5",
                "score": score,
            }
            with near_signals_lock:
                near_signals.append(candidate)
            continue

        # Реальный сигнал
        with stats_lock:
            stats["signals"] += 1

        price = ticker["lastPrice"]

        risk_amount = ACCOUNT_EQUITY * (RISK_PER_TRADE_PCT / 100.0)
        stop_distance = price * (STOP_PCT / 100.0)
        if stop_distance <= 0:
            continue
        position_size = risk_amount / stop_distance
        tp1_price = price * (1 - (STOP_PCT / 100.0) * TP1_RR)
        tp2_price = price * (1 - (STOP_PCT / 100.0) * TP2_RR)

        why_lines = [
            "• Сильный памп + высокая ликвидность",
            "• Высокий funding и перекос в лонги",
            "• Exhaustion‑свеча + volume climax",
            "• Ложный пробой локального максимума",
            "• Медвежья CVD‑дивергенция",
        ]
        why_text = "\n".join(why_lines)

        msg = (
            f"🔥 **SHORT — {sym}** (Score: {score}/8)\n\n"
            f"📈 Памп 24ч: +{ticker['price24hPcnt']:.1f}%\n"
            f"💰 Цена: {price:.5f}\n"
            f"💸 Funding: {funding:.3f}%\n"
            f"👥 Лонги (аккаунты): {longs:.0f}%\n\n"
            f"🧠 *Почему вход:*\n{why_text}\n\n"
            f"🎯 *План сделки:*\n"
            f"Вход: market / откат от зоны ложного пробоя\n"
            f"Стоп: +{STOP_PCT:.1f}% (≈ {stop_distance:.4f}) над локальным хайем\n"
            f"TP1 (1:{TP1_RR:.0f}): {tp1_price:.5f}\n"
            f"TP2 (1:{TP2_RR:.0f}): {tp2_price:.5f}\n\n"
            f"💼 Риск: {RISK_PER_TRADE_PCT:.1f}% от депозита (~{risk_amount:.2f} USD)\n"
            f"Размер позиции: ~{position_size:.3f} контрактов\n\n"
            f"https://www.bybit.com/trade/usdt/{sym}"
        )

        send_telegram_message(msg)
        logger.info("Signal sent for %s with score %d", sym, score)
        time.sleep(2)


# ================== ОТЧЁТ РАЗ В N ЧАСОВ ==================
def send_periodic_report():
    global last_report_time
    now = datetime.utcnow()
    if now - last_report_time < timedelta(hours=REPORT_INTERVAL_HOURS):
        return

    with stats_lock:
        s = stats.copy()
    with near_signals_lock:
        # Берём последних/лучших MAX_NEAR_SIGNALS_IN_REPORT
        # сортировка по score (если есть)
        sorted_near = sorted(
            near_signals,
            key=lambda x: x.get("score", 0),
            reverse=True,
        )[:MAX_NEAR_SIGNALS_IN_REPORT]

    lines = []
    lines.append("📊 *Промежуточный отчёт бота*")
    lines.append(f"Период: последние ~{REPORT_INTERVAL_HOURS} ч.")
    lines.append("")
    lines.append(f"Сканирований: {s['scan_count']}")
    lines.append(f"Всего символов просмотрено: {s['symbols_total']}")
    lines.append(f"После фильтра пампа/ликвидности: {s['after_pump']}")
    lines.append(f"После сантимента (funding+longs): {s['after_sentiment']}")
    lines.append(f"После паттернов (exhaustion+climax+fake): {s['after_patterns']}")
    lines.append(f"После CVD‑дивергенции: {s['after_cvd']}")
    lines.append(f"Реальных сигналов за период: {s['signals']}")
    lines.append("")

    if sorted_near:
        lines.append("⚠️ *Почти сигналы (нужен ручной взгляд):*")
        for c in sorted_near:
            t = c["ticker"]
            symbol = c["symbol"]
            funding = c["funding"]
            longs = c["longs"]
            reason = c.get("reason", "—")
            score = c.get("score", 0)
            line = (
                f"- {symbol}: памп {t['price24hPcnt']:.1f}%, "
                f"оборот {t['turnover24h']/1_000_000:.1f}M, "
                f"funding {funding:.3f}%, longs {longs:.0f}%, "
                f"score {score}/8 — {reason}"
            )
            lines.append(line)
    else:
        lines.append("Почти сигналов за период не было (рынок не даёт сетапы под стратегию).")

    msg = "\n".join(lines)
    send_telegram_message(msg)

    # Сброс статистики и «почти сигналов» на новый период
    reset_stats()


