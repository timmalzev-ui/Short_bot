def get_all_linear_symbols() -> List[str]:
    url = f"{BASE_URL}/v5/market/instruments-info?category=linear"
    try:
        resp = requests.get(url, timeout=5)
        resp.raise_for_status()
        data = resp.json()
        return [
            i["symbol"]
            for i in data["result"]["list"]
            if i.get("quoteCoin") == "USDT"
        ]
    except Exception as e:
        logger.exception("Error in get_all_linear_symbols: %s", e)
