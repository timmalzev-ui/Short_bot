# ================== TELEGRAM (УЛУЧШЕННАЯ ВЕРСИЯ) ==================
def send_telegram_message(text: str) -> None:
    """Отправка с retry и увеличенным timeout"""
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
    payload = {"chat_id": CHAT_ID, "text": text, "parse_mode": "Markdown"}
    
    for attempt in range(3):
        try:
            resp = requests.post(url, json=payload, timeout=20)
            if resp.status_code == 200:
                logger.info("✅ Telegram OK: %s", text[:50])
                return
            logger.warning("Telegram HTTP %d: %s", resp.status_code, resp.text)
        except Exception as e:
            logger.warning("Telegram attempt %d error: %s", attempt+1, str(e))
        
        if attempt < 2:
            time.sleep(2 ** attempt)
    
    logger.error("❌ Telegram полностью упал после 3 попыток")

